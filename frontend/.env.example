VITE_SIGNALING_URL=ws://localhost:8080/ws

# Optional: a self-hosted coturn instance for production NAT traversal.
# Leave unset for local dev — a public STUN server is enough when both
# peers can reach each other directly. Comma-separate multiple URLs to
# offer coturn's udp/tcp/tls variants (see signaling-server deployment
# notes for a typical coturn config).
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
